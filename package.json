{
  "name": "404-found",
  "version": "1.0.0",
  "private": true,
  "description": "Offline-first PWA mesh messaging with LibP2P, Ed25519 crypto, and Capacitor",
  "scripts": {
    "dev": "next dev frontend -p 3000",
    "dev:turbo": "next dev frontend -p 3000 --turbopack",
    "build": "next build frontend",
    "build:static": "next build frontend",
    "build:cap": "npm run build && npm run cap:copy",
    "start": "next start frontend -p 3000",
    "lint": "next lint frontend",
    "type-check": "tsc --noEmit -p frontend/tsconfig.json",
    "clean": "rimraf frontend/.next frontend/out android ios",
    "clean:all": "rimraf frontend/.next frontend/out frontend/node_modules android ios node_modules",
    "postinstall": "cd frontend && npm install",
    "worker:build": "webpack --config webpack.workers.cjs",
    "worker:watch": "webpack --config webpack.workers.cjs --watch",
    "proto:compile": "echo 'Proto compilation skipped - using runtime loading'",
    "cap:init": "cd frontend && cap init",
    "cap:sync": "cd frontend && cap sync",
    "cap:copy": "cd frontend && cap copy",
    "cap:update": "cd frontend && cap update",
    "cap:android": "cd frontend && cap run android",
    "cap:ios": "cd frontend && cap run ios",
    "cap:open:android": "cd frontend && cap open android",
    "cap:open:ios": "cd frontend && cap open ios",
    "cap:add:android": "cd frontend && cap add android",
    "cap:add:ios": "cd frontend && cap add ios",
    "preview": "next build frontend && next start frontend -p 3000",
    "analyze": "cross-env ANALYZE=true next build frontend"
  },
  "dependencies": {
    "@capacitor-community/bluetooth-le": "^6.0.0",
    "@capacitor/app": "^6.0.0",
    "@capacitor/core": "^6.0.0",
    "@capacitor/local-notifications": "^6.0.0",
    "@chainsafe/libp2p-gossipsub": "^14.0.0",
    "@chainsafe/libp2p-noise": "^16.0.0",
    "@chainsafe/libp2p-yamux": "^7.0.0",
    "@hookform/resolvers": "^3.9.1",
    "@libp2p/bootstrap": "^11.0.0",
    "@libp2p/circuit-relay-v2": "^4.2.2",
    "@libp2p/identify": "^3.0.0",
    "@libp2p/mdns": "^12.0.18",
    "@libp2p/tcp": "^10.0.0",
    "@libp2p/webrtc": "^5.0.0",
    "@libp2p/websockets": "^9.0.0",
    "@noble/ed25519": "^2.1.0",
    "@noble/hashes": "^1.5.0",
    "@radix-ui/react-accordion": "1.2.12",
    "@radix-ui/react-alert-dialog": "1.1.15",
    "@radix-ui/react-aspect-ratio": "1.1.8",
    "@radix-ui/react-avatar": "1.1.11",
    "@radix-ui/react-checkbox": "1.3.3",
    "@radix-ui/react-collapsible": "1.1.12",
    "@radix-ui/react-context-menu": "2.2.16",
    "@radix-ui/react-dialog": "1.1.15",
    "@radix-ui/react-dropdown-menu": "2.1.16",
    "@radix-ui/react-hover-card": "1.1.15",
    "@radix-ui/react-label": "2.1.8",
    "@radix-ui/react-menubar": "1.1.16",
    "@radix-ui/react-navigation-menu": "1.2.14",
    "@radix-ui/react-popover": "1.1.15",
    "@radix-ui/react-progress": "1.1.8",
    "@radix-ui/react-radio-group": "1.3.8",
    "@radix-ui/react-scroll-area": "1.2.10",
    "@radix-ui/react-select": "2.2.6",
    "@radix-ui/react-separator": "1.1.8",
    "@radix-ui/react-slider": "1.3.6",
